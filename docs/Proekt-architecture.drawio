        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- SERVER / APPLICATION LAYER                          -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="30" value="APPLICATION LAYER — Javalin Server (Java)"
          style="swimlane;startSize=35;fontStyle=1;fontSize=12;fillColor=#F0FFF0;strokeColor=#2D8A2D;fontColor=#1A4A1A;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="370" width="1574" height="870" as="geometry"/>
        </mxCell>

        <!-- Middleware -->
        <mxCell id="31" value="&lt;b style=&quot;color:#7D5200;font-size:12px&quot;&gt;🛡️  MIDDLEWARE / SECURITY FILTER  (app.before)&lt;/b&gt;     ·  Intercepts all /api/* requests  ·  Skips /api/login &amp;amp; /api/register  ·  Validates JWT (HMAC256)  ·  Extracts userId + Role  ·  Injects User object into request context"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;align=left;verticalAlign=middle;spacingLeft=14;fontSize=11;"
          vertex="1" parent="30">
          <mxGeometry x="20" y="50" width="1534" height="75" as="geometry"/>
        </mxCell>

        <!-- API Endpoints -->
        <mxCell id="32" value="&lt;b style=&quot;color:#1A4A1A;font-size:12px&quot;&gt;🔌  REST API ENDPOINTS&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-family:monospace;font-size:11px&quot;&gt;&lt;b style=&quot;color:#27AE60&quot;&gt;POST&lt;/b&gt;  /api/register                      Register new user                    [Public]&lt;br&gt;&lt;b style=&quot;color:#27AE60&quot;&gt;POST&lt;/b&gt;  /api/login                          Authenticate user, returns JWT       [Public]&lt;br&gt;&lt;b style=&quot;color:#E67E22&quot;&gt;PUT&lt;/b&gt;   /api/change-password                Update password (verify old first)   [🔒 JWT]&lt;br&gt;&lt;b style=&quot;color:#27AE60&quot;&gt;POST&lt;/b&gt;  /api/documents                      Create new document + version 1      [🔒 Author / Admin]&lt;br&gt;&lt;b style=&quot;color:#27AE60&quot;&gt;POST&lt;/b&gt;  /api/documents/{id}/versions        Submit new version for approval      [🔒 Author / Admin]&lt;br&gt;&lt;b style=&quot;color:#E67E22&quot;&gt;PUT&lt;/b&gt;   /api/documents/{id}/review          Approve or reject pending version    [🔒 Reviewer / Admin]&lt;br&gt;&lt;b style=&quot;color:#2980B9&quot;&gt;GET&lt;/b&gt;   /api/documents/pending              Get all versions awaiting review     [🔒 Reviewer / Admin]&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;verticalAlign=top;spacingLeft=14;spacingTop=10;fontSize=11;"
          vertex="1" parent="30">
          <mxGeometry x="20" y="140" width="1534" height="205" as="geometry"/>
        </mxCell>

        <!-- DTOs -->
        <mxCell id="40" value="&lt;b style=&quot;color:#006064;font-size:11px&quot;&gt;📦  DTOs:&lt;/b&gt;   LoginRequest  ·  LoginResponse (JWT + role)  ·  RegisterRequest  ·  ChangePasswordRequest  ·  CreateDocumentRequest  ·  CreateVersionRequest  ·  DocumentDTO  ·  PendingVersionDTO  ·  ReviewVersionRequest"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F7FA;strokeColor=#00ACC1;align=left;verticalAlign=middle;spacingLeft=14;fontSize=11;"
          vertex="1" parent="30">
          <mxGeometry x="20" y="360" width="1534" height="55" as="geometry"/>
        </mxCell>

        <!-- Services Container -->
        <mxCell id="50" value="SERVICE LAYER — Core Business Logic"
          style="swimlane;startSize=30;fontStyle=1;fontSize=11;fillColor=#E8EAF6;strokeColor=#3F51B5;fontColor=#1A237E;"
          vertex="1" parent="30">
          <mxGeometry x="20" y="430" width="1534" height="265" as="geometry"/>
        </mxCell>

        <mxCell id="51" value="&lt;b style=&quot;color:#4A235A;font-size:12px&quot;&gt;🔑  AuthService&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#333&quot;&gt;&lt;b&gt;register()&lt;/b&gt;&lt;br&gt;  BCrypt hash password → DB insert&lt;br&gt;&lt;br&gt;&lt;b&gt;login()&lt;/b&gt;&lt;br&gt;  Retrieve user from DB&lt;br&gt;  Verify BCrypt → Issue JWT token&lt;br&gt;&lt;br&gt;&lt;b&gt;changePassword()&lt;/b&gt;&lt;br&gt;  Verify old password&lt;br&gt;  Re-hash new password → Update DB&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#7E57C2;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;"
          vertex="1" parent="50">
          <mxGeometry x="10" y="40" width="480" height="210" as="geometry"/>
        </mxCell>

        <mxCell id="52" value="&lt;b style=&quot;color:#0D47A1;font-size:12px&quot;&gt;📄  DocumentService  (Core Logic)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#333&quot;&gt;&lt;b&gt;createDocument()&lt;/b&gt;  AUTHOR/ADMIN · transaction (commit/rollback) · audit log&lt;br&gt;&lt;b&gt;createNewVersion()&lt;/b&gt;  Creates version with status PENDING_APPROVAL · transaction&lt;br&gt;&lt;b&gt;reviewVersion()&lt;/b&gt;  Changes status APPROVED / REJECTED · REVIEWER/ADMIN · transaction&lt;br&gt;&lt;b&gt;getDocumentWithHistory()&lt;/b&gt;  Returns document + all versions sorted descending&lt;br&gt;&lt;b&gt;getDocumentList()&lt;/b&gt;  Returns ACTIVE documents only (default), filter by author&lt;br&gt;&lt;b&gt;getPendingVersions()&lt;/b&gt;  Returns all versions awaiting review (for Reviewer)&lt;br&gt;&lt;b&gt;addComment()&lt;/b&gt;  Adds reviewer comment to a specific version&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;"
          vertex="1" parent="50">
          <mxGeometry x="500" y="40" width="530" height="210" as="geometry"/>
        </mxCell>

        <mxCell id="53" value="&lt;b style=&quot;color:#880E4F;font-size:12px&quot;&gt;👥  RoleService&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#333&quot;&gt;&lt;b&gt;requestRoleChange()&lt;/b&gt;&lt;br&gt;  User submits role-change request&lt;br&gt;&lt;br&gt;&lt;b&gt;getPendingRequests()&lt;/b&gt;&lt;br&gt;  Admin view of pending requests&lt;br&gt;&lt;br&gt;&lt;b&gt;approveRequest()&lt;/b&gt;&lt;br&gt;  → Updates user.role in DB&lt;br&gt;&lt;br&gt;&lt;b&gt;rejectRequest()&lt;/b&gt;&lt;br&gt;  → Sets request status = REJECTED&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C2185B;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;"
          vertex="1" parent="50">
          <mxGeometry x="1040" y="40" width="484" height="210" as="geometry"/>
        </mxCell>

        <!-- Security Block -->
        <mxCell id="60" value="&lt;b style=&quot;color:#4A1A00;font-size:12px&quot;&gt;🔐  SECURITY COMPONENTS&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;🔒 &lt;b&gt;BCrypt&lt;/b&gt;: One-way hashing · Salt included · Secure password storage     |     🪙 &lt;b&gt;JWT HMAC256&lt;/b&gt;: payload = userId + username + role + expiry  ·  TTL: 20h (72,000,000 ms)     |     🛡️ &lt;b&gt;RBAC&lt;/b&gt;: Role-Based Access Control (AUTHOR | REVIEWER | READER | ADMIN)     |     ⚡ &lt;b&gt;Transactions&lt;/b&gt;: setAutoCommit(false) → commit / rollback on error     |     📋 &lt;b&gt;Audit Trail&lt;/b&gt;: CREATE_DOCUMENT · CREATE_VERSION · REVIEW_VERSION → logged with user_id + timestamp     |     🌍 &lt;b&gt;Env Vars&lt;/b&gt;: JWT_SECRET · DB_URL · DB_USER&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;align=left;verticalAlign=top;spacingLeft=14;spacingTop=10;fontSize=11;"
          vertex="1" parent="30">
          <mxGeometry x="20" y="710" width="1534" height="120" as="geometry"/>
        </mxCell>

        <!-- Arrow: Server → DB -->
        <mxCell id="70" value=""
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;startArrow=block;endFill=1;startFill=1;strokeColor=#7B1FA2;strokeWidth=2;"
          edge="1" source="30" target="80" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="71" value="&lt;b&gt;JDBC  ·  Connection / PreparedStatement  ·  Manual SQL Queries&lt;/b&gt;"
