        </mxCell>
        <mxCell id="21" value="&lt;b&gt;HTTP / REST · JSON&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555&quot;&gt;Authorization: Bearer &amp;lt;JWT&amp;gt;&lt;/font&gt;"
          style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;fillColor=#ffffff;strokeColor=#4A90D9;rounded=1;fontSize=11;"
